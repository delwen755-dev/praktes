{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd bloodmap_api && composer install --no-dev --prefer-dist --optimize-autoloader --no-interaction && ls -la vendor && ls -la vendor/composer && echo vendor-installed",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 10,
      "includeFiles": "**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|svg|webp|ico|woff|woff2|eot|ttf|json|txt|xml))$",
      "destination": "/bloodmap_api/public/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
